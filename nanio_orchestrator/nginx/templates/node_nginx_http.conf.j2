# Generated by nanio-orchestrator for node: {{ member_address }}
# Pool: {{ pool_name }} (http, read-only serve)
server {
    listen 80;
    server_name _;

    root {{ data_dir }};
    autoindex off;
    expires 30d;
    add_header Cache-Control "public, immutable";
    add_header Accept-Ranges bytes;

    gzip_static on;
    gzip_types text/plain application/json application/javascript text/css;

    location / {
        try_files $uri =404;
    }
}

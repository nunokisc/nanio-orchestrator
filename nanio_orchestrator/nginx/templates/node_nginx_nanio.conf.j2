# Generated by nanio-orchestrator for node: {{ member_address }}
# Pool: {{ pool_name }} (nanio+nginx, shared storage)
upstream local-nanio {
    server 127.0.0.1:{{ nanio_port }};
    keepalive 32;
}

server {
    listen 80;
    server_name _;

    client_max_body_size 0;
    proxy_request_buffering off;
    proxy_buffering         off;

    # S3 write operations → nanio
    location / {
        proxy_pass         http://local-nanio;
        proxy_http_version 1.1;
        proxy_set_header   Host       $host;
        proxy_set_header   Connection "";
    }
}

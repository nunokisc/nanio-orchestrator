# Generated by nanio-orchestrator for node: {{ member_address }}
[Unit]
Description=nanio S3-compatible storage ({{ pool_name }})
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/nanio serve --options /etc/nanio/options.toml
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

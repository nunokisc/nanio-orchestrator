# managed by nanio-orchestrator
# vhost_id:{{ vhost.id }} name:{{ vhost.server_name }} updated:{{ updated }}
server {
{% if vhost.ssl %}
    listen {{ vhost.listen_port }} ssl;
    http2  on;
{% else %}
    listen {{ vhost.listen_port }};
{% endif %}
    server_name {{ vhost.server_name }};
{% if vhost.ssl and vhost.ssl_cert_path %}

    ssl_certificate     {{ vhost.ssl_cert_path }};
    ssl_certificate_key {{ vhost.ssl_key_path }};
{% endif %}
{% if extra_blocks_ssl %}
{% for block in extra_blocks_ssl %}

    {{ block.content | indent(4) }}
{% endfor %}
{% endif %}

    client_max_body_size 0;
    proxy_request_buffering off;
    proxy_buffering         off;
{% if vhost.extra_directives %}

    {{ vhost.extra_directives }}
{% endif %}
{% if extra_blocks_proxy %}
{% for block in extra_blocks_proxy %}

    {{ block.content | indent(4) }}
{% endfor %}
{% endif %}
{% for route in routes %}
{% if route.enabled %}

    # route_id:{{ route.id }} prefix:{{ route.path_prefix }}{% if route.migration_dst_pool_name %} [LIVE MIGRATION → {{ route.migration_dst_pool_name }}]{% endif %}

    location {{ route.path_prefix }} {
{% if route.migration_dst_pool_name %}
        # Live migration split routing:
        #   writes (PUT/POST/DELETE) → destination pool ({{ route.migration_dst_pool_name }})
        #   reads  (GET/HEAD)        → source pool ({{ route.pool_name }}), 404-fallback to destination
        error_page 418 = @nanio_mig_{{ route.id }};
        if ($request_method !~ ^(GET|HEAD|OPTIONS)$) { return 418; }
        proxy_intercept_errors on;
        error_page 404 = @nanio_mig_{{ route.id }};
{% elif route.key_prefix %}
        rewrite ^{{ route.path_prefix }}(.*)$ /{{ route.key_prefix }}$1 break;
{% endif %}
        proxy_pass         http://{{ route.pool_name }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        "";
{% if route.extra_directives %}
        {{ route.extra_directives }}
{% endif %}
    }
{% endif %}
{% endfor %}
{% for route in routes %}
{% if route.enabled and route.migration_dst_pool_name %}

    # Named fallback/write location for live migration route_id:{{ route.id }}
    location @nanio_mig_{{ route.id }} {
        proxy_pass         http://{{ route.migration_dst_pool_name }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        "";
    }
{% endif %}
{% endfor %}
{% if extra_blocks_end %}
{% for block in extra_blocks_end %}

    {{ block.content | indent(4) }}
{% endfor %}
{% endif %}
}
